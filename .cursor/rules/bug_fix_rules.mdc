```python
# 端到端测试
import pytest
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC

class TestLoginFlow:
    def setup_method(self):
        self.driver = webdriver.Chrome()
        self.driver.get("http://localhost:3000/login")
    
    def teardown_method(self):
        self.driver.quit()
    
    def test_successful_login_flow(self):
        """测试完整登录流程"""
        # 输入有效凭据
        email_input = self.driver.find_element(By.ID, "email")
        password_input = self.driver.find_element(By.ID, "password")
        login_button = self.driver.find_element(By.XPATH, "//button[text()='登录']")
        
        email_input.send_keys("test@example.com")
        password_input.send_keys("validpassword")
        login_button.click()
        
        # 验证跳转到dashboard
        WebDriverWait(self.driver, 10).until(
            EC.url_contains("/dashboard")
        )
        
        assert "/dashboard" in self.driver.current_url
    
    def test_login_with_invalid_credentials(self):
        """测试无效凭据登录"""
        email_input = self.driver.find_element(By.ID, "email")
        password_input = self.driver.find_element(By.ID, "password")
        login_button = self.driver.find_element(By.XPATH, "//button[text()='登录']")
        
        email_input.send_keys("invalid@example.com")
        password_input.send_keys("wrongpassword")
        login_button.click()
        
        # 验证错误消息显示
        error_message = WebDriverWait(self.driver, 5).until(
            EC.presence_of_element_located((By.CLASS_NAME, "error-message"))
        )
        
        assert "用户不存在" in error_message.text or "密码错误" in error_message.text
