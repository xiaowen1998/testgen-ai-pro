```python
# 监控代码示例
import time
import logging
from functools import wraps

def monitor_login_performance(func):
    @wraps(func)
    async def wrapper(*args, **kwargs):
        start_time = time.time()
        try:
            result = await func(*args, **kwargs)
            duration = time.time() - start_time
            
            # 记录成功指标
            logging.info(f"登录成功 - 耗时: {duration:.2f}s")
            return result
            
        except Exception as e:
            duration = time.time() - start_time
            
            # 记录失败指标
            logging.error(f"登录失败 - 耗时: {duration:.2f}s, 错误: {str(e)}")
            raise
            
    return wrapper

@monitor_login_performance
