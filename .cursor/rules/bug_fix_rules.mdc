# 修复前 - 有BUG的代码
@router.post("/login")
async def login(request: LoginRequest):
    # 问题：未验证输入格式，查询方式不安全
    user = db.query(f"SELECT * FROM users WHERE email = '{request.email}'")
    if user and user.password == request.password:  # 明文密码比较
        return {"token": "fake_token"}
    raise HTTPException(status_code=401, detail="Login failed")

# 修复后 - 安全的代码
@router.post("/login")
async def login(request: LoginRequest, db: Session = Depends(get_db)):
    try:
        # 1. 输入验证
        if not request.email or not request.password:
            raise HTTPException(status_code=400, detail="邮箱和密码不能为空")
        
        # 2. 邮箱格式验证
        if not re.match(r'^[^@]+@[^@]+\.[^@]+$', request.email):
            raise HTTPException(status_code=400, detail="邮箱格式不正确")
        
        # 3. 安全的数据库查询
        user = db.query(User).filter(User.email == request.email).first()
        if not user:
            raise HTTPException(status_code=404, detail="用户不存在")
        
        # 4. 安全的密码验证
        if not verify_password(request.password, user.hashed_password):
            raise HTTPException(status_code=401, detail="密码错误")
        
        # 5. 生成JWT Token
        access_token = create_access_token(data={"sub": user.email})
        
        logger.info(f"用户 {user.email} 登录成功")
        return {"access_token": access_token, "token_type": "bearer"}
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"登录处理异常: {str(e)}")
        raise HTTPException(status_code=500, detail="内部服务器错误")
```

