# PrintAutoTestcases - 测试用例生成专业规范

## 核心目标
根据需求文档（PDF/Word）生成符合行业标准的专业测试用例，涵盖功能测试、接口测试、安全测试、兼容性测试等。

## 测试用例设计方法论

### 1. 功能测试用例设计

#### 1.1 等价类划分法
```python
class EquivalenceClassTest:
    """等价类划分测试用例生成"""
    
    @staticmethod
    def generate_equivalence_cases(field_info: Dict) -> List[TestCase]:
        """
        根据字段信息生成等价类测试用例
        
        Args:
            field_info: 字段信息 {
                "name": "用户名",
                "type": "string", 
                "valid_range": "3-20字符",
                "format": "字母数字下划线"
            }
        """
        cases = []
        
        # 有效等价类
        cases.append({
            "case_id": f"EC_Valid_{field_info['name']}",
            "case_name": f"{field_info['name']}有效等价类测试",
            "test_data": "admin123",
            "expected_result": "输入成功",
            "test_type": "功能测试-等价类划分",
            "priority": "高"
        })
        
        # 无效等价类 - 长度不符
        cases.append({
            "case_id": f"EC_Invalid_Length_{field_info['name']}",
            "case_name": f"{field_info['name']}长度无效等价类测试", 
            "test_data": "ab",  # 少于3字符
            "expected_result": "提示长度错误",
            "test_type": "功能测试-等价类划分",
            "priority": "高"
        })
        
        # 无效等价类 - 格式不符
        cases.append({
            "case_id": f"EC_Invalid_Format_{field_info['name']}",
            "case_name": f"{field_info['name']}格式无效等价类测试",
            "test_data": "admin@123",  # 包含特殊字符
            "expected_result": "提示格式错误", 
            "test_type": "功能测试-等价类划分",
            "priority": "高"
        })
        
        return cases
```

#### 1.2 边界值分析法
```python
class BoundaryValueTest:
    """边界值测试用例生成"""
    
    @staticmethod
    def generate_boundary_cases(field_info: Dict) -> List[TestCase]:
        """生成边界值测试用例"""
        cases = []
        
        if field_info.get("min_length") and field_info.get("max_length"):
            min_len = field_info["min_length"]
            max_len = field_info["max_length"]
            
            # 最小值边界
            cases.extend([
                {
                    "case_id": f"BV_Min_{field_info['name']}",
                    "case_name": f"{field_info['name']}最小值边界测试",
                    "test_data": "a" * min_len,
                    "expected_result": "输入成功",
                    "test_type": "功能测试-边界值分析"
                },
                {
                    "case_id": f"BV_Min_Minus1_{field_info['name']}",
                    "case_name": f"{field_info['name']}最小值-1边界测试",
                    "test_data": "a" * (min_len - 1),
                    "expected_result": "提示长度过短",
                    "test_type": "功能测试-边界值分析"
                }
            ])
            
            # 最大值边界
            cases.extend([
                {
                    "case_id": f"BV_Max_{field_info['name']}",
                    "case_name": f"{field_info['name']}最大值边界测试",
                    "test_data": "a" * max_len,
                    "expected_result": "输入成功",
                    "test_type": "功能测试-边界值分析"
                },
                {
                    "case_id": f"BV_Max_Plus1_{field_info['name']}",
                    "case_name": f"{field_info['name']}最大值+1边界测试",
                    "test_data": "a" * (max_len + 1),
                    "expected_result": "提示长度过长",
                    "test_type": "功能测试-边界值分析"
                }
            ])
        
        return cases
```

#### 1.3 错误推断法
```python
class ErrorGuessingTest:
    """错误推断法测试用例生成"""
    
    @staticmethod
    def generate_error_guessing_cases(functionality: str) -> List[TestCase]:
        """基于经验生成错误推断测试用例"""
        cases = []
        
        # 常见错误场景
        common_errors = {
            "登录": [
                {"data": "", "error": "空用户名密码"},
                {"data": "' OR '1'='1", "error": "SQL注入攻击"},
                {"data": "<script>alert('xss')</script>", "error": "XSS攻击"},
                {"data": "admin\x00admin", "error": "空字节注入"}
            ],
            "文件上传": [
                {"data": "test.php", "error": "恶意文件上传"},
                {"data": "../../etc/passwd", "error": "路径遍历攻击"},
                {"data": "10GB.file", "error": "超大文件上传"},
                {"data": "virus.exe", "error": "病毒文件上传"}
            ]
        }
        
        if functionality in common_errors:
            for i, error_case in enumerate(common_errors[functionality]):
                cases.append({
                    "case_id": f"EG_{functionality}_{i+1}",
                    "case_name": f"{functionality}错误推断-{error_case['error']}",
                    "test_data": error_case["data"],
                    "expected_result": "系统正确拒绝或处理",
                    "test_type": "功能测试-错误推断法",
                    "priority": "中"
                })
        
        return cases
```

### 2. 接口测试用例设计

#### 2.1 API接口测试
```python
class APITestCaseGenerator:
    """API接口测试用例生成器"""
    
    @staticmethod
    def generate_api_test_cases(api_info: Dict) -> List[TestCase]:
        """生成API接口测试用例"""
        cases = []
        
        # 正常调用测试
        cases.append({
            "case_id": f"API_Normal_{api_info['name']}",
            "case_name": f"{api_info['name']}正常调用测试",
            "method": api_info["method"],
            "url": api_info["url"],
            "headers": {"Content-Type": "application/json"},
            "request_body": api_info.get("sample_request", {}),
            "expected_status": 200,
            "expected_response": api_info.get("sample_response", {}),
            "test_type": "接口测试-功能验证"
        })
        
        # 参数缺失测试
        cases.append({
            "case_id": f"API_MissingParam_{api_info['name']}",
            "case_name": f"{api_info['name']}必填参数缺失测试",
            "method": api_info["method"],
            "url": api_info["url"],
            "headers": {"Content-Type": "application/json"},
            "request_body": {},
            "expected_status": 400,
            "expected_response": {"error": "参数缺失"},
            "test_type": "接口测试-异常验证"
        })
        
        # 非法参数测试
        cases.append({
            "case_id": f"API_InvalidParam_{api_info['name']}",
            "case_name": f"{api_info['name']}非法参数测试",
            "method": api_info["method"],
            "url": api_info["url"],
            "headers": {"Content-Type": "application/json"},
            "request_body": {"invalid": "data"},
            "expected_status": 400,
            "expected_response": {"error": "参数格式错误"},
            "test_type": "接口测试-异常验证"
        })
        
        # 权限验证测试
        cases.append({
            "case_id": f"API_Auth_{api_info['name']}",
            "case_name": f"{api_info['name']}权限验证测试",
            "method": api_info["method"],
            "url": api_info["url"],
            "headers": {"Content-Type": "application/json"},  # 不包含Authorization
            "request_body": api_info.get("sample_request", {}),
            "expected_status": 401,
            "expected_response": {"error": "未授权访问"},
            "test_type": "接口测试-安全验证"
        })
        
        return cases
```

