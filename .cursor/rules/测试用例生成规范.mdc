## 数据模型优化

### 测试用例数据模型
```python
from sqlalchemy import Column, Integer, String, Text, DateTime, ForeignKey, Enum
from sqlalchemy.orm import relationship
from enum import Enum as PyEnum

class TestCaseType(PyEnum):
    FUNCTIONAL = "功能测试"
    INTERFACE = "接口测试" 
    SECURITY = "安全测试"
    COMPATIBILITY = "兼容性测试"
    PERFORMANCE = "性能测试"

class TestCasePriority(PyEnum):
    HIGH = "高"
    MEDIUM = "中"
    LOW = "低"

class TestCase(Base):
    """测试用例模型"""
    __tablename__ = "test_cases"
    
    id = Column(Integer, primary_key=True, index=True)
    case_id = Column(String(50), unique=True, index=True, nullable=False)
    case_name = Column(String(200), nullable=False)
    document_id = Column(String, ForeignKey("documents.id"), nullable=False)
    
    # 测试用例分类
    test_type = Column(Enum(TestCaseType), nullable=False)
    test_subtype = Column(String(100), nullable=True)  # 如：等价类划分、边界值分析
    priority = Column(Enum(TestCasePriority), default=TestCasePriority.MEDIUM)
    
    # 测试内容
    preconditions = Column(Text, nullable=True)
    test_steps = Column(Text, nullable=False)  # JSON格式存储步骤数组
    test_data = Column(Text, nullable=True)
    expected_result = Column(Text, nullable=False)
    
    # 设计方法
    design_method = Column(String(50), nullable=True)  # 设计方法：等价类、边界值等
    test_category = Column(String(20), nullable=True)  # 正向测试、负向测试
    
    # 扩展信息
    severity = Column(String(20), nullable=True)  # 对于安全测试用例
    cwe_id = Column(String(20), nullable=True)     # CWE编号
    test_environment = Column(String(200), nullable=True)  # 测试环境要求
    
    # 关联关系
    document = relationship("Document", back_populates="test_cases")
    
    created_at = Column(DateTime, default=datetime.utcnow)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
```

## XMind结构优化

### 测试用例专用XMind模板
```python
class TestCaseXMindGenerator:
    """测试用例专用XMind生成器"""
    
    @staticmethod
    def generate_testcase_xmind(test_cases: List[TestCase], product_name: str) -> Dict:
        """生成测试用例XMind结构"""
        
        # 按测试类型分组
        grouped_cases = {}
        for case in test_cases:
            test_type = case.test_type.value
            if test_type not in grouped_cases:
                grouped_cases[test_type] = {}
            
            subtype = case.test_subtype or "其他"
            if subtype not in grouped_cases[test_type]:
                grouped_cases[test_type][subtype] = []
            
            grouped_cases[test_type][subtype].append(case)
        
        # 构建XMind结构
        modules = []
        for test_type, subtypes in grouped_cases.items():
            # 创建测试类型模块
            module = {
                "name": test_type,
                "menus": []
            }
            
            for subtype, cases in subtypes.items():
                # 创建子类型菜单
                menu = {
                    "name": subtype,
                    "children": []
                }
                
                for case in cases:
                    # 创建测试用例
                    case_node = {
                        "name": f"{case.case_id} - {case.case_name}",
                        "type": "case",
                        "steps": [
                            {"text": f"优先级: {case.priority.value}", "resource": "属性"},
                            {"text": f"前置条件: {case.preconditions or '无'}", "resource": "前置条件"},
                            {"text": "测试步骤:", "resource": "步骤标题"}
                        ]
                    }
                    
                    # 添加具体测试步骤
                    if case.test_steps:
                        try:
                            steps = json.loads(case.test_steps)
                            for i, step in enumerate(steps, 1):
                                case_node["steps"].append({
                                    "text": f"步骤{i}: {step}",
                                    "resource": "测试步骤"
                                })
                        except json.JSONDecodeError:
                            case_node["steps"].append({
                                "text": case.test_steps,
                                "resource": "测试步骤"
                            })
                    
                    # 添加测试数据和预期结果
                    if case.test_data:
                        case_node["steps"].append({
                            "text": f"测试数据: {case.test_data}",
                            "resource": "测试数据"
                        })
                    
                    case_node["steps"].append({
                        "text": f"预期结果: {case.expected_result}",
                        "resource": "预期结果"
                    })
                    
                    menu["children"].append(case_node)
                
                module["menus"].append(menu)
            
            modules.append(module)
        
        return XMindTestcaseGenerator.generate_xmind(f"{product_name}测试用例", modules)
```

---

**重要提醒**: 
- 测试用例生成必须基于专业的测试设计方法论
- AI生成的用例需要人工review和优化
- 不同类型的测试用例需要不同的设计策略
- 测试用例应该具备良好的可执行性和可验证性