class CompatibilityTestGenerator:
    """兼容性测试用例生成器"""
    
    @staticmethod
    def generate_browser_compatibility_cases() -> List[TestCase]:
        """生成浏览器兼容性测试用例"""
        cases = []
        browsers = [
            {"name": "Chrome", "versions": ["120", "119", "118"]},
            {"name": "Firefox", "versions": ["119", "118", "117"]},
            {"name": "Safari", "versions": ["17", "16", "15"]},
            {"name": "Edge", "versions": ["119", "118", "117"]}
        ]
        
        for browser in browsers:
            for version in browser["versions"]:
                cases.append({
                    "case_id": f"COMPAT_Browser_{browser['name']}_{version}",
                    "case_name": f"{browser['name']} {version}浏览器兼容性测试",
                    "test_environment": f"{browser['name']} {version}",
                    "test_steps": [
                        f"在{browser['name']} {version}浏览器中打开应用",
                        "测试主要功能是否正常",
                        "检查页面显示是否正确",
