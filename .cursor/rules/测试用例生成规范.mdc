                    ],
                    "expected_result": "所有功能正常，页面显示正确",
                    "test_type": "兼容性测试-浏览器",
                    "priority": "中"
                })
        
        return cases
    
    @staticmethod
    def generate_device_compatibility_cases() -> List[TestCase]:
