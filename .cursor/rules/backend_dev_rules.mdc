### 错误处理规范
```python
import logging
from fastapi import HTTPException
from sqlalchemy.exc import IntegrityError
from typing import Any

logger = logging.getLogger(__name__)

class ServiceException(Exception):
    """业务逻辑异常"""
    def __init__(self, message: str, code: int = 400):
        self.message = message
        self.code = code
        super().__init__(message)

async def handle_service_errors(func, *args, **kwargs) -> Any:
    """统一服务错误处理装饰器"""
    try:
        return await func(*args, **kwargs)
    except ServiceException as e:
        raise HTTPException(status_code=e.code, detail=e.message)
    except IntegrityError as e:
        logger.error(f"数据库完整性错误: {str(e)}")
        raise HTTPException(status_code=409, detail="数据冲突")
    except Exception as e:
        logger.error(f"未知错误: {str(e)}")
        raise HTTPException(status_code=500, detail="内部服务器错误")
```

## 数据库规范

### 模型定义
```python
from sqlalchemy import Column, Integer, String, DateTime, Text, Boolean, ForeignKey
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import relationship
from datetime import datetime

Base = declarative_base()

class BaseModel(Base):
    """基础模型类"""
    __abstract__ = True
    
    id = Column(Integer, primary_key=True, index=True)
    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    is_deleted = Column(Boolean, default=False)

class User(BaseModel):
    """用户模型"""
    __tablename__ = "users"
    
    email = Column(String(255), unique=True, index=True, nullable=False)
    hashed_password = Column(String(255), nullable=False)
    is_active = Column(Boolean, default=True)
    is_superuser = Column(Boolean, default=False)
    
    # 关联关系
    documents = relationship("Document", back_populates="user")
    
    def __repr__(self):
        return f"<User(email='{self.email}')>"
```

### 数据库操作规范
```python
from sqlalchemy.orm import Session
from sqlalchemy.exc import IntegrityError
from typing import Optional, List
import logging

logger = logging.getLogger(__name__)

class BaseRepository:
    """基础仓储类"""
    
    def __init__(self, db: Session):
        self.db = db
    
    async def get_by_id(self, model_class, id: int) -> Optional[Any]:
        """根据ID获取对象"""
        try:
            return self.db.query(model_class).filter(
                model_class.id == id,
                model_class.is_deleted == False
            ).first()
        except Exception as e:
            logger.error(f"查询对象失败: {str(e)}")
            raise
    
    async def create(self, model_class, **kwargs) -> Any:
        """创建对象"""
        try:
            obj = model_class(**kwargs)
            self.db.add(obj)
            self.db.commit()
            self.db.refresh(obj)
            return obj
        except IntegrityError as e:
            self.db.rollback()
            logger.error(f"创建对象失败，数据冲突: {str(e)}")
            raise ServiceException("数据冲突，请检查输入", 409)
        except Exception as e:
            self.db.rollback()
            logger.error(f"创建对象失败: {str(e)}")
            raise
    
    async def soft_delete(self, obj: Any) -> bool:
        """软删除对象"""
        try:
            obj.is_deleted = True
            obj.updated_at = datetime.utcnow()
            self.db.commit()
            return True
        except Exception as e:
            self.db.rollback()
            logger.error(f"删除对象失败: {str(e)}")
            raise
```

## 服务层规范

### 服务类结构
```python
from abc import ABC, abstractmethod
from typing import Optional, List, Dict, Any
import logging

logger = logging.getLogger(__name__)

class BaseService(ABC):
    """基础服务类"""
    
    def __init__(self, repository: BaseRepository):
        self.repository = repository
    
    @abstractmethod
    async def validate_input(self, **kwargs) -> bool:
        """输入验证"""
        pass

class DocumentService(BaseService):
    """文档服务类"""
    
    async def validate_input(self, title: str, **kwargs) -> bool:
        """验证文档输入"""
        if not title or len(title.strip()) == 0:
            raise ServiceException("文档标题不能为空")
        if len(title) > 255:
            raise ServiceException("文档标题长度不能超过255字符")
        return True
    
    async def create_document(
        self, 
        title: str, 
        content: Optional[str] = None,
        user_id: int = None
    ) -> Document:
        """创建文档"""
        await self.validate_input(title=title)
        
        # 检查用户是否存在
        user = await self.repository.get_by_id(User, user_id)
        if not user:
            raise ServiceException("用户不存在", 404)
        
        # 创建文档
        document = await self.repository.create(
            Document,
            title=title.strip(),
            content=content,
            user_id=user_id
        )
        
        logger.info(f"用户 {user_id} 创建文档: {document.id}")
        return document
    
    async def get_user_documents(
        self, 
        user_id: int, 
        page: int = 1, 
        size: int = 10
    ) -> Dict[str, Any]:
        """获取用户文档列表"""
        try:
            offset = (page - 1) * size
            query = self.repository.db.query(Document).filter(
                Document.user_id == user_id,
                Document.is_deleted == False
            )
            
            total = query.count()
            documents = query.offset(offset).limit(size).all()
            
            return {
                "items": documents,
                "total": total,
                "page": page,
                "size": size,
                "pages": (total + size - 1) // size
            }
        except Exception as e:
            logger.error(f"获取用户文档失败: {str(e)}")
            raise
```

