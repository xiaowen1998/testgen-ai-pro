## 交互设计规范

### 反馈机制

#### 1. 加载状态
```tsx
import React, { useState } from 'react';
import { Button, Spin, Skeleton, Card } from 'antd';

const LoadingStates: React.FC = () => {
  const [loading, setLoading] = useState(false);
  const [dataLoading, setDataLoading] = useState(true);

  return (
    <div>
      {/* 按钮加载 */}
      <Button 
        type="primary" 
        loading={loading}
        onClick={() => setLoading(true)}
      >
        {loading ? '提交中...' : '提交'}
      </Button>

      {/* 页面加载 */}
      <Spin spinning={loading} tip="加载中...">
        <Card>
          <p>页面内容</p>
        </Card>
      </Spin>

      {/* 数据加载骨架屏 */}
      <Card>
        <Skeleton loading={dataLoading} active>
          <p>实际数据内容</p>
        </Skeleton>
      </Card>
    </div>
  );
};
```

