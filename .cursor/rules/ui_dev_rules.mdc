### 键盘导航
```tsx
import React, { useRef, useEffect } from 'react';
import { Modal, Button, Input } from 'antd';

const AccessibleModal: React.FC = () => {
  const [visible, setVisible] = React.useState(false);
  const firstInputRef = useRef<any>(null);

  useEffect(() => {
    if (visible && firstInputRef.current) {
      // 模态框打开时自动聚焦到第一个输入框
      firstInputRef.current.focus();
    }
  }, [visible]);

  const handleKeyDown = (e: React.KeyboardEvent) => {
    // ESC键关闭模态框
    if (e.key === 'Escape') {
      setVisible(false);
    }
  };

  return (
    <div>
      <Button onClick={() => setVisible(true)}>
        打开模态框
      </Button>
      
      <Modal
        title="无障碍模态框"
        open={visible}
        onCancel={() => setVisible(false)}
        onKeyDown={handleKeyDown}
        destroyOnClose
        autoFocus
        restoreFocus
      >
        <Input
          ref={firstInputRef}
          placeholder="第一个输入框"
          aria-label="第一个输入框"
        />
        <Input
          style={{ marginTop: 16 }}
          placeholder="第二个输入框"
          aria-label="第二个输入框"
        />
      </Modal>
    </div>
  );
};
```

## 性能优化规范

### 图片优化
```tsx
import React, { useState } from 'react';
import { Image, Skeleton } from 'antd';

const OptimizedImage: React.FC<{ src: string; alt: string }> = ({ src, alt }) => {
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(false);

  return (
    <div style={{ position: 'relative' }}>
      {loading && <Skeleton.Image active />}
      
      <Image
        src={src}
        alt={alt}
        style={{ display: loading ? 'none' : 'block' }}
        placeholder={<Skeleton.Image />}
        fallback="data:image/png;base64," // 默认占位图
        onLoad={() => setLoading(false)}
        onError={() => {
          setError(true);
          setLoading(false);
        }}
        lazy // 懒加载
      />
    </div>
  );
};
```

### 长列表优化
```tsx
import React from 'react';
import { List, Avatar } from 'antd';
import { FixedSizeList as VirtualList } from 'react-window';

interface ItemData {
  id: string;
  title: string;
  description: string;
}

const VirtualizedList: React.FC<{ data: ItemData[] }> = ({ data }) => {
  const Row = ({ index, style }: { index: number; style: React.CSSProperties }) => (
    <div style={style}>
      <List.Item>
        <List.Item.Meta
          avatar={<Avatar size={40}>{data[index].title[0]}</Avatar>}
          title={data[index].title}
          description={data[index].description}
        />
      </List.Item>
    </div>
  );

  return (
    <VirtualList
      height={400} // 可视区域高度
      itemCount={data.length}
      itemSize={73} // 每个项目的高度
      width="100%"
    >
      {Row}
    </VirtualList>
  );
};
```

## 测试规范

### 组件测试
```tsx
import React from 'react';
import { render, screen, fireEvent, waitFor } from '@testing-library/react';
import { Button, message } from 'antd';
import '@testing-library/jest-dom';

// 测试组件
const TestButton: React.FC = () => {
  const handleClick = () => {
    message.success('点击成功');
  };

  return (
    <Button type="primary" onClick={handleClick}>
      点击我
    </Button>
  );
};

// 测试用例
describe('TestButton', () => {
  test('renders button with correct text', () => {
    render(<TestButton />);
    expect(screen.getByText('点击我')).toBeInTheDocument();
  });

  test('has primary type class', () => {
    render(<TestButton />);
    const button = screen.getByRole('button');
    expect(button).toHaveClass('ant-btn-primary');
  });

  test('shows success message on click', async () => {
    const mockMessage = jest.spyOn(message, 'success');
    render(<TestButton />);
    
    fireEvent.click(screen.getByText('点击我'));
    
    await waitFor(() => {
      expect(mockMessage).toHaveBeenCalledWith('点击成功');
    });
  });
});
```

