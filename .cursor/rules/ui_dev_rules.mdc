### 组件库文档
```tsx
/**
 * 用户卡片组件
 * 
 * @example
 * ```tsx
 * <UserCard 
 *   user={{ name: '张三', email: 'zhangsan@example.com' }}
 *   showEdit={true}
 *   onEdit={(user) => console.log('编辑用户', user)}
 * />
 * ```
 */
interface UserCardProps {
  /** 用户信息 */
  user: {
    name: string;
    email: string;
    avatar?: string;
  };
  /** 是否显示编辑按钮 */
  showEdit?: boolean;
  /** 编辑回调函数 */
  onEdit?: (user: UserCardProps['user']) => void;
}

const UserCard: React.FC<UserCardProps> = ({ user, showEdit = false, onEdit }) => {
  // 组件实现
};
