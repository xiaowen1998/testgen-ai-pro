### 表单验证规范

#### 1. 实时验证
```tsx
import React from 'react';
import { Form, Input, Button } from 'antd';

const ValidateForm: React.FC = () => {
  const [form] = Form.useForm();

  const validateUsername = async (rule: any, value: string) => {
    if (value && value.length < 3) {
      throw new Error('用户名至少3个字符');
    }
    if (value && !/^[a-zA-Z0-9_]+$/.test(value)) {
      throw new Error('用户名只能包含字母、数字和下划线');
    }
  };

  return (
    <Form form={form} layout="vertical">
      <Form.Item
        label="用户名"
        name="username"
        hasFeedback
        rules={[
          { required: true, message: '请输入用户名' },
          { validator: validateUsername }
        ]}
      >
        <Input placeholder="输入用户名" />
      </Form.Item>

      <Form.Item
        label="密码"
        name="password"
        hasFeedback
        rules={[
          { required: true, message: '请输入密码' },
          { min: 8, message: '密码至少8个字符' },
          { pattern: /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/, message: '密码需包含大小写字母和数字' }
        ]}
      >
        <Input.Password placeholder="输入密码" />
      </Form.Item>

      <Form.Item
        label="确认密码"
        name="confirmPassword"
        dependencies={['password']}
        hasFeedback
        rules={[
          { required: true, message: '请确认密码' },
          ({ getFieldValue }) => ({
            validator(_, value) {
              if (!value || getFieldValue('password') === value) {
                return Promise.resolve();
              }
              return Promise.reject(new Error('两次输入密码不一致'));
            },
          }),
        ]}
      >
        <Input.Password placeholder="再次输入密码" />
      </Form.Item>

      <Form.Item>
        <Button type="primary" htmlType="submit">
          提交
        </Button>
      </Form.Item>
    </Form>
  );
};
```

## 响应式设计规范

### 断点系统
```css
/* Ant Design 断点系统 */
@media (max-width: 575px) {
  /* xs: 超小屏幕 手机 */
  .responsive-hide-xs { display: none !important; }
}

@media (min-width: 576px) and (max-width: 767px) {
  /* sm: 小屏幕 平板 */
  .responsive-hide-sm { display: none !important; }
}

@media (min-width: 768px) and (max-width: 991px) {
  /* md: 中等屏幕 小桌面 */
  .responsive-hide-md { display: none !important; }
}

@media (min-width: 992px) and (max-width: 1199px) {
  /* lg: 大屏幕 桌面 */
  .responsive-hide-lg { display: none !important; }
}

@media (min-width: 1200px) and (max-width: 1599px) {
  /* xl: 超大屏幕 大桌面 */
  .responsive-hide-xl { display: none !important; }
}

@media (min-width: 1600px) {
  /* xxl: 超超大屏幕 */
  .responsive-hide-xxl { display: none !important; }
}
```

### 响应式组件
```tsx
import React from 'react';
import { Table, Card, Space, Button } from 'antd';
import { useMediaQuery } from 'react-responsive';

const ResponsiveComponent: React.FC = () => {
  const isMobile = useMediaQuery({ maxWidth: 767 });
